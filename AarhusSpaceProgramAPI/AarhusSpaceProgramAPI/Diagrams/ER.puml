@startchen
entity Manager {
    Department
    ManagerId <<key>>
    Name 
    HireDate
}

entity Mission {
    MissionId <<key>>
    Name 
    LaunchDate
    Duration
    Status
    Type
}

entity Launchpad{
    LaunchpadId <<key>>
    Location 
    CurrentStatus
    MaxWeight
}

entity Astronaut{
    AstronautId <<key>>
    Name 
    Rank
    Paygrade
    HireDate
    ExpInSpace
    ExpInSim
}

entity Scientist {
    ScientistId <<key>>
    Name 
    Title
    Specialty
    HireDate
}

entity Rocket{
    RocketId <<key>>
    Model 
    PayloadCapacity
    CrewCapacity
    Stages
    FuelCapacity
    Weight
}

entity Celestial_body{
    bodyId <<key>>
    Name
    Distance
    Composition
    bodyType
}

entity Experiment{
    ExperiemntId <<key>>
    ExperimentName
    Description
    CreatedAt
}


relationship Launch_from{
}
relationship Has{
}
relationship Assigned{
}
relationship Assigned_to{
}
relationship Participate{
}
relationship Target{
}
relationship Orbiting{
}
relationship Assigned_experiment{
}
relationship Belongs_to{
}



Mission -1- Launch_from
Launch_from -N- Launchpad

Manager -1- Has
Has -N- Mission

Astronaut -(1,N)- Assigned
Assigned -N- Mission

Scientist -N- Participate
Participate -N- Mission

Rocket -1- Assigned_to
Assigned_to -1- Mission

Mission -N- Target
Target -1- Celestial_body

Celestial_body -N- Orbiting
Orbiting -1- Celestial_body

Scientist -1- Assigned_experiment
Assigned_experiment -N- Experiment

Experiment -N- Belongs_to
Belongs_to -1- Mission







@endchen
